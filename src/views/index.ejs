<!DOCTYPE html>
<html lang="pt-br">
<%- include('partials/components/head') %>
<body>
  <%- include('partials/components/header') %>
    <main class="container">
      <section>
        <article class="content-article parallax-layer layer-1">
              <div class="mb-5 mt-5">
                <h1>BOOK STORE</h1>
              </div>
              <h4>Plataforma API: Desenvolvendo o Futuro da Integração e Automação</h4>
              <p class="text-width">
                  Nossa API foi meticulosamente projetada para proporcionar uma experiência fluida e eficiente, abrangendo várias
                  áreas-chave de nossa plataforma. Seja você um desenvolvedor experiente ou alguém que está explorando a programação pela primeira vez,
                  nossa API foi criada com a usabilidade em mente, oferecendo endpoints intuitivos e documentação detalhada para garantir uma integração
                  bem-sucedida.
              </p>
        </article>
      </section >
      
      <section class="parallax">
          <article class="container">
            <div class="content-article">
              <h2 class="mb-4">Documentação</h2>
              <div class="row doc-list ">
    
                  <div class="col-md-4">
                      <h2>Crud</h2>
                      <ul id="list-crud">
                          <li id="crudbooks">Books</li>
                          <li id="crudusers">Users</li>
                          <li id="cruduserinfo">User Information</li>
                          <li id="crudcart">Cart</li>
                          <li id="crudpay">Payment</li>
                          <li id="crudfb">Feedback</li>
                      </ul>
                  </div>
    
                  <div class="col-md-4">
                      <h2>Advance Search</h2>
                      <ul>
                          <li>Books</li>
                          <li>Users</li>
                          <li>Payment</li>
                          <li>Feedback</li>
                      </ul>
                  </div>
    
                  <div class="col-md-4">
                    <h2>Auth</h2>
                    <ul>
                        <li>Auth</li>
                        <li>Token invalid</li>
                    </ul>
                  </div>
    
              </div>
            </div>
          </article>
    
          <div class="bg-doc">
            <article class="container">
              <div class="documents_style" id="doc-select">
                <div id="crudbooks-doc" class="display-off"><%- include('partials/doc/BooksCrud') %></div>
                <div id="crudusers-doc" class="display-off" ><%- include('partials/doc/UsersCrud') %></div>
                <div id="cruduserinfo-doc" class="display-off" ><%- include('partials/doc/UsersInfoCrud') %></div>
                <div id="crudcart-doc" class="display-off" ><%- include('partials/doc/CartCrud') %></div>
                <div id="crudpay-doc" class="display-off" ><%- include('partials/doc/PaymentCrud') %></div>
                <div id="crudfb-doc" class="display-off" ><%- include('partials/doc/FeedbackCrud') %></div>
              </div>
            </article>
          </div>
      </section>

      <!-- documentação completa da api, sua visualização será feita atravez do click do usuário -->
      
      <!-- fim da documentação-->
      <div class="floating-button">Up</div>
    </main>
    <%- include('partials/components/footer') %>
</body>
</html>